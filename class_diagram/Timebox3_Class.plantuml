@startuml
hide circle
skinparam classAttributeIconSize 0
title Timebox 3 - Class Diagram (Timetable, Attendance, Communication)

class User {
  +id: int
  +name: string
  +email: string
  +role: enum
  +photo: string
  +email_verified_at: datetime
  --
  +FillGetData()
  +Login()
  +Logout()
  +Register()
  +UpdateProfile()
  +ResetPassword()
  +VerifyEmail()
  +GetRole()
  +AutoID()
}

class Student {
  +id: int
  +user_id: int
  +student_no: string
  +full_name: string
  +programme: string
  +status: enum
  --
  +FillGetData()
  +GetAttendance()
  +AutoID()
}

class Subject {
  +id: int
  +course_id: int
  +subject_code: string
  +title: string
  +credits: int
  +description: text
  +photo: string
  --
  +FillGetData()
  +SearchSubject()
  +GetTimetables()
  +GetAttendances()
  +AutoID()
}

class Timetable {
  +id: int
  +subject_id: int
  +created_by: int
  +day_of_week: string
  +start_time: time
  +end_time: time
  +location: string
  --
  +AddTimetable()
  +UpdateTimetable()
  +DeleteTimetable()
  +CheckConflict()
  +SearchTimetable()
  +GetByCourse()
  +GetBySubject()
  +GetByStudent()
  +GetByTeacher()
  +GetCreator()
  +AutoID()
}

class Attendance {
  +id: int
  +subject_id: int
  +student_id: int
  +date: date
  +status: enum
  --
  +RecordAttendance()
  +UpdateAttendance()
  +CalculateRate()
  +FillGetData()
  +MarkPresent()
  +MarkAbsent()
  +SearchAttendance()
  +GetByStudent()
  +GetBySubject()
  +GetByDate()
  +AutoID()
}

class LowAttendanceAlertState {
  +id: int
  +student_id: int
  +last_rate: float
  +is_below_threshold: bool
  --
  +UpdateState()
  +CheckThreshold()
  +SendAlert()
  +FillGetData()
  +GetByStudent()
  +GetStudentsBelowThreshold()
  +ResetAlert()
  +AutoID()
}

class Announcement {
  +id: int
  +user_id: int
  +title: string
  +body: text
  +priority: enum
  +require_ack: bool
  --
  +CreateAnnouncement()
  +UpdateAnnouncement()
  +DeleteAnnouncement()
  +Publish()
  +FillGetData()
  +SearchAnnouncement()
  +GetVisibleToUser()
  +IsExpired()
  +AutoID()
}

class AnnouncementRead {
  +id: int
  +announcement_id: int
  +user_id: int
  +read_at: datetime
  +acknowledged_at: datetime
  --
  +MarkAsRead()
  +MarkAsAcknowledged()
  +FillGetData()
  +GetReadStatus()
  +GetByUser()
  +GetByAnnouncement()
  +AutoID()
}

class Message {
  +id: int
  +sender_id: int
  +receiver_id: int
  +body: text
  +read: bool
  --
  +SendMessage()
  +MarkAsRead()
  +FillGetData()
  +DeleteMessage()
  +GetInbox()
  +GetSent()
  +SearchMessages()
  +GetConversation()
  +AutoID()
}

class Notification {
  +id: int
  +notifiable_id: int
  +type: string
  +data: json
  +read_at: datetime
  --
  +MarkAsRead()
  +GetUnread()
  +FillGetData()
  +GetByUser()
  +Notify()
  +AutoID()
}

class ContactMessage {
  +id: int
  +first_name: string
  +last_name: string
  +email: string
  +subject: string
  +message: text
  --
  +SubmitContact()
  +MarkAsRead()
  +FillGetData()
  +SearchContactMessage()
  +GetUnread()
  +Reply()
  +AutoID()
}

class FeedbackMessage {
  +id: int
  +name: string
  +email: string
  +type: string
  +message: text
  +is_read: bool
  --
  +SubmitFeedback()
  +MarkAsRead()
  +FillGetData()
  +MarkAsReplied()
  +SearchFeedbackMessage()
  +GetUnread()
  +AutoID()
}

' Relationships
Subject "1" -- "0..*" Timetable
User    "1" -- "0..*" Timetable : created_by

Subject "1" -- "0..*" Attendance
Student "1" -- "0..*" Attendance

' Each Student can have 0 or 1 alert state; each state belongs to 1 Student.
Student "1" -- "0..1" LowAttendanceAlertState

User "1" -- "0..*" Announcement
Announcement "1" -- "0..*" AnnouncementRead
User "1" -- "0..*" AnnouncementRead

User "1" -- "0..*" Message : sender
User "1" -- "0..*" Message : receiver

User "1" -- "0..*" Notification

@enduml