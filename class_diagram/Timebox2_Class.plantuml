@startuml
hide circle
skinparam classAttributeIconSize 0
title Timebox 2 - Class Diagram (Grades, Fees, Assignments)

class Student {
  +id: int
  +user_id: int
  +student_no: string
  +full_name: string
  +programme: string
  +status: enum
  --
  +FillGetData()
  +GetGrades()
  +GetFees()
  +GetAttendance()
  +CalculateGPA()
  +AutoID()
}

class User {
  +id: int
  +name: string
  +email: string
  +role: enum
  +photo: string
  +email_verified_at: datetime
  --
  +FillGetData()
  +Login()
  +Logout()
  +Register()
  +UpdateProfile()
  +ResetPassword()
  +VerifyEmail()
  +GetRole()
  +AutoID()
}

class Course {
  +id: int
  +course_code: string
  +title: string
  +credits: int
  +semester: string
  +photo: string
  --
  +FillGetData()
  +SearchCourse()
  +GetSubjects()
  +GetEnrollments()
  +AutoID()
}

class Subject {
  +id: int
  +course_id: int
  +subject_code: string
  +title: string
  +credits: int
  +description: text
  +photo: string
  --
  +FillGetData()
  +SearchSubject()
  +GetGrades()
  +GetTimetables()
  +GetAttendances()
  +AutoID()
}

class Grade {
  +id: int
  +subject_id: int
  +course_id: int
  +student_id: int
  +graded_by: int
  +reviewed_by: int
  +score: decimal
  +status: enum
  --
  +FillGetData()
  +SubmitGrade()
  +ApproveGrade()
  +RejectGrade()
  +GetLetterGrade()
  +SearchGrade()
  +GetByStudent()
  +GetBySubject()
  +AutoID()
}

class GradeReviewLog {
  +id: int
  +grade_id: int
  +performed_by: int
  +action: string
  +reason: string
  --
  +FillGetData()
  +LogAction()
  +GetByGrade()
  +SearchLog()
  +AutoID()
}

class Fee {
  +id: int
  +student_id: int
  +amount: decimal
  +description: string
  +status: enum
  +due_date: date
  +paid_date: date
  --
  +FillGetData()
  +CreateFee()
  +UpdateFee()
  +ApprovePayment()
  +RejectPayment()
  +GenerateReceipt()
  +SearchFee()
  +GetLatePayments()
  +AutoID()
}

class Assignment {
  +id: int
  +subject_id: int
  +course_id: int
  +created_by: int
  +title: string
  +due_date: date
  +max_score: int
  +status: enum
  --
  +FillGetData()
  +CreateAssignment()
  +UpdateAssignment()
  +PublishAssignment()
  +GetSubmissions()
  +IsOverdue()
  +CanSubmit()
  +AutoID()
}

class AssignmentSubmission {
  +id: int
  +assignment_id: int
  +student_id: int
  +file_path: string
  +score: decimal
  +feedback: string
  +graded_by: int
  +status: enum
  --
  +FillGetData()
  +Submit()
  +GradeSubmission()
  +IsGraded()
  +UpdateScore()
  +GetPercentage()
  +GetByStudent()
  +GetByAssignment()
  +AutoID()
}

' Relationships
Course  "1" -- "0..*" Subject
Subject "1" -- "0..*" Grade
Student "1" -- "0..*" Grade
User    "1" -- "0..*" Grade : graded_by / reviewed_by
Grade   "1" -- "0..*" GradeReviewLog

Student "1" -- "0..*" Fee

Subject "1" -- "0..*" Assignment
Course  "1" -- "0..*" Assignment
User    "1" -- "0..*" Assignment : created_by
Assignment "1" -- "0..*" AssignmentSubmission
Student    "1" -- "0..*" AssignmentSubmission
User       "1" -- "0..*" AssignmentSubmission : graded_by

@enduml