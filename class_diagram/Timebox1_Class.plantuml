@startuml Timebox1_Class
hide circle
skinparam classAttributeIconSize 0
title Timebox 1 - Student Registration and Course Registration

class User {
  +id: bigint
  +name: varchar
  +email: varchar
  +role: varchar
  +photo: varchar
  +preferences: json
  +email_verified_at: timestamp
  --
  +student()
  +teachingCourses()
  +teachingSubjects()
  +hasRole(role)
  +isStudent()
  +isTeacher()
  +isStaff()
}

class Student {
  +id: bigint
  +user_id: bigint
  +student_no: varchar
  +full_name: varchar
  +dob: date
  +gender: varchar
  +email: varchar
  +phone: varchar
  +programme: varchar
  +intake_year: varchar
  +status: varchar
  +photo: varchar
  +id_card: varchar
  +transcript: varchar
  +enrollment_date: date
  --
  +user()
  +courses()
  +attendances()
  +grades()
  +fees()
  +calculateGPA()
  +requestEnrollment(course)
  +requestWithdrawal(course)
}

class Course {
  +id: bigint
  +course_code: varchar
  +title: varchar
  +credits: int
  +semester: varchar
  +photo: varchar
  --
  +students()
  +teachers()
  +subjects()
  +attendances()
  +grades()
  +timetables()
}

class Subject {
  +id: bigint
  +course_id: bigint
  +subject_code: varchar
  +title: varchar
  +credits: int
  +description: text
  +photo: varchar
  --
  +course()
  +teachers()
  +grades()
  +timetables()
  +attendances()
}

class CourseStudent <<pivot: course_student>> {
  +id: bigint
  +course_id: bigint
  +student_id: bigint
  +status: enum
  +created_at: timestamp
  +updated_at: timestamp
}

class CourseTeacher <<pivot: course_teacher>> {
  +id: bigint
  +course_id: bigint
  +user_id: bigint
  +created_at: timestamp
  +updated_at: timestamp
}

class SubjectTeacher <<pivot: subject_teacher>> {
  +id: bigint
  +subject_id: bigint
  +user_id: bigint
  +created_at: timestamp
  +updated_at: timestamp
}

class EnrollmentService {
  +requestEnrollment(student, course)
  +requestWithdrawal(student, course)
  +approveEnrollment(enrollmentId)
  +rejectEnrollment(enrollmentId)
  +approveWithdrawal(enrollmentId)
  +rejectWithdrawal(enrollmentId)
}

User "1" -- "0..1" Student : has profile
Course "1" -- "0..*" Subject : has
Course "1" -- "0..*" CourseStudent
Student "1" -- "0..*" CourseStudent
Course "1" -- "0..*" CourseTeacher
User "1" -- "0..*" CourseTeacher : teaches
Subject "1" -- "0..*" SubjectTeacher
User "1" -- "0..*" SubjectTeacher : teaches

EnrollmentService ..> CourseStudent : manages status
EnrollmentService ..> Course : checks conflicts
EnrollmentService ..> Student : validates ownership

@enduml
