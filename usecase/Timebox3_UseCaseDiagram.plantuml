@startuml Timebox3_UseCaseDiagram
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam dpi 300

scale 0.9
skinparam defaultFontSize 9
skinparam ranksep 8
skinparam nodesep 8
skinparam RectanglePadding 5

actor "Student" as Student #BFDBFE
actor "Teacher" as Teacher #FEF9C3
actor "Staff"   as Staff   #BBF7D0
actor "Guest"   as Guest   #E5E7EB

rectangle "University Academic Portal\nTimebox 3: Timetable, Attendance & Communication" #FFFFFF {

  rectangle "Manage Timetable" #E0F2FE {
    usecase "Manage Timetable" as UC_TimetableManage
    usecase "View Timetable"   as UC_TimetableView
  }

  rectangle "Manage Attendance" #DCFCE7 {
    usecase "Record Attendance"       as UC_AttendanceRecord
    usecase "View Attendance"         as UC_AttendanceView
    usecase "Attendance Reports"      as UC_AttendanceReport
    usecase "Low Attendance Alerts"   as UC_AttendanceAlert
  }

  rectangle "Manage Announcement" #F5F5F4 {
    usecase "Manage Announcements"    as UC_AnnouncementManage
    usecase "View Announcements"      as UC_AnnouncementView
    usecase "Acknowledge Announcement" as UC_AnnouncementAck
  }

  rectangle "Manage Messages" #FCE7F3 {
    usecase "Send Message"  as UC_MessageSend
    usecase "View Messages" as UC_MessageView
  }

  rectangle "Manage Contact & Feedback" #FEF9C3 {
    usecase "Submit Contact Message"   as UC_ContactSubmit
    usecase "Submit Feedback Message"  as UC_FeedbackSubmit
    usecase "Manage Contact & Feedback" as UC_ContactFeedbackManage
  }

  rectangle "Manage Notifications" #EDE9FE {
    usecase "View Notifications"       as UC_NotificationView
    usecase "Manage Notifications"     as UC_NotificationManage
  }
}

' Guest
Guest -[#6B7280]-> UC_ContactSubmit
Guest -[#6B7280]-> UC_FeedbackSubmit

' Student
Student -[#2563EB]-> UC_TimetableView
Student -[#2563EB]-> UC_AttendanceView
Student -[#2563EB]-> UC_AnnouncementView
Student -[#2563EB]-> UC_AnnouncementAck
Student -[#2563EB]-> UC_MessageSend
Student -[#2563EB]-> UC_MessageView
Student -[#2563EB]-> UC_NotificationView
Student -[#2563EB]-> UC_NotificationManage

' Teacher
Teacher -[#CA8A04]-> UC_TimetableView
Teacher -[#CA8A04]-> UC_AttendanceRecord
Teacher -[#CA8A04]-> UC_AttendanceView
Teacher -[#CA8A04]-> UC_AnnouncementManage
Teacher -[#CA8A04]-> UC_AnnouncementView
Teacher -[#CA8A04]-> UC_AnnouncementAck
Teacher -[#CA8A04]-> UC_MessageSend
Teacher -[#CA8A04]-> UC_MessageView
Teacher -[#CA8A04]-> UC_NotificationView
Teacher -[#CA8A04]-> UC_NotificationManage

' Staff
Staff -[#16A34A]-> UC_TimetableManage
Staff -[#16A34A]-> UC_TimetableView
Staff -[#16A34A]-> UC_AttendanceReport
Staff -[#16A34A]-> UC_AttendanceAlert
Staff -[#16A34A]-> UC_AnnouncementManage
Staff -[#16A34A]-> UC_AnnouncementView
Staff -[#16A34A]-> UC_AnnouncementAck
Staff -[#16A34A]-> UC_MessageSend
Staff -[#16A34A]-> UC_MessageView
Staff -[#16A34A]-> UC_ContactFeedbackManage
Staff -[#16A34A]-> UC_NotificationView
Staff -[#16A34A]-> UC_NotificationManage

@enduml
