@startuml Timebox1_UseCaseDiagram_Simple
left to right direction
scale 1.6
skinparam dpi 300
skinparam packageStyle rectangle
skinparam shadowing false

actor Guest #LightGray
actor Student #LightBlue
actor Staff #LightGreen

rectangle "University Academic Portal\n(Timebox 1: Student Registration & Course Registration)" #White {

  package "Manage User" #AliceBlue {
    usecase "Register User" as UC_RegisterUser
    usecase "User Login" as UC_Login
    usecase "Password Management" as UC_Password
    usecase "User Settings / Preferences" as UC_Preferences
    usecase "Global Search" as UC_GlobalSearch
  }

  package "Manage Student" #MintCream {
    usecase "Register Student" as UC_RegisterStudent
    usecase "Student Self-Profile\n(View / Update Own Profile)" as UC_SelfProfile
  }

  package "Manage Course Registration" #Beige {
    usecase "Request Enrolment" as UC_RequestEnroll
    usecase "Request Withdrawal" as UC_RequestWithdraw
    usecase "View My Courses" as UC_ViewMyCourses

    usecase "Approve / Reject Enrolment" as UC_ApproveRejectEnroll
    usecase "Approve / Reject Withdrawal" as UC_ApproveRejectWithdraw
    usecase "Search & Manage Enrolments" as UC_ManageEnrollments
  }
}

' ===== Actor Relationships =====
Guest -[#Gray]-> UC_RegisterUser
Guest -[#Gray]-> UC_Login
Guest -[#Gray]-> UC_Password
Guest -[#Gray]-> UC_GlobalSearch

Student -[#Blue]-> UC_Login
Student -[#Blue]-> UC_Password
Student -[#Blue]-> UC_Preferences
Student -[#Blue]-> UC_GlobalSearch
Student -[#Blue]-> UC_RegisterStudent
Student -[#Blue]-> UC_SelfProfile
Student -[#Blue]-> UC_RequestEnroll
Student -[#Blue]-> UC_RequestWithdraw
Student -[#Blue]-> UC_ViewMyCourses

Staff -[#DarkGreen]-> UC_Login
Staff -[#DarkGreen]-> UC_Password
Staff -[#DarkGreen]-> UC_Preferences
Staff -[#DarkGreen]-> UC_GlobalSearch
Staff -[#DarkGreen]-> UC_RegisterStudent
Staff -[#DarkGreen]-> UC_ApproveRejectEnroll
Staff -[#DarkGreen]-> UC_ApproveRejectWithdraw
Staff -[#DarkGreen]-> UC_ManageEnrollments

@enduml
